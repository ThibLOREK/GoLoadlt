# Environnement actif : dev | preprod | prod
ACTIVE_ENV=dev

# Répertoires de données
PROJECTS_DIR=./projects
CONNECTIONS_DIR=./connections

# Adresse du serveur HTTP
SERVER_ADDR=:8080

# Exemple de secret référencé dans une connexion XML :
# <env name="dev" host="localhost" port="5432" db="mydb" user="user" secretRef="${DB_PASSWORD_DEV}"/>
DB_PASSWORD_DEV=changeme
DB_PASSWORD_PREPROD=changeme
DB_PASSWORD_PROD=changeme
